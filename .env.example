# Cirklon MCP Server Configuration
# Copy to .env and adjust for your setup

# MIDI port names (substring match, case-insensitive)
# Run list_midi_ports tool to see available ports
CIRKLON_OUTPUT_PORT=Cirklon
CIRKLON_INPUT_PORT=Cirklon

# Remote control channel (1-16, Cirklon default is 16)
CIRKLON_REMOTE_CHANNEL=16

# Auto-connect on server start
CIRKLON_AUTO_CONNECT=true

# Default BPM for clock sender
CIRKLON_DEFAULT_BPM=120
